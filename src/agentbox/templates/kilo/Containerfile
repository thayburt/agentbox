FROM @@BASE_IMAGE@@

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        bash \
        ca-certificates \
        curl \
        git \
        jq \
        less \
        nodejs \
        npm \
        openssh-client \
        python3 \
        ripgrep \
        sudo \
    && rm -rf /var/lib/apt/lists/*

RUN npm install -g @kilocode/cli \
    && kilo --version

USER ubuntu

WORKDIR /workspace
